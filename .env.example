# ══════════════════════════════════════════════════════════════
# CODEBA Dashboard — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores conforme necessário.
# ══════════════════════════════════════════════════════════════

# Servidor
HOST=127.0.0.1
PORT=8000

# Logging
LOG_LEVEL=INFO
LOG_DIR=logs

# Upload
UPLOAD_DIR=temp_uploads
MAX_FILE_SIZE_MB=50

# Persistência (SQLite)
DATABASE_PATH=data/auditoria.db

# RPA (credenciais — NUNCA commitar .env com esses valores preenchidos)
# OPENPORT_USER=
# OPENPORT_PASS=
# RPA_DOWNLOAD_DIR=
